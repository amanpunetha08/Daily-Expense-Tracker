{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/push-reminder",
      "schedule": "30 3,15 * * *"
    },
    {
      "path": "/api/cron/whatsapp-reminder",
      "schedule": "30 3,15 * * *"
    }
  ]
}
